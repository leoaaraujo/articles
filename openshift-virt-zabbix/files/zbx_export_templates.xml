                <item>
                    <uuid>5f0c18e214e0471bb2b5f72e6f4056d1</uuid>
                    <name>Thanos API latency (p95)</name>
                    <type>HTTP_AGENT</type>
                    <key>thanos.api.latency.p95</key>
                    <value_type>FLOAT</value_type>
                    <units>s</units>
                    <preprocessing>
                        <step>
                            <type>JSONPATH</type>
                            <parameters>
                                <parameter>$.data.result[0].value[1]</parameter>
                            </parameters>
                        </step>
                    </preprocessing>
                    <url>{$PROM_URL}/api/v1/query</url>
                    <query_fields>
                        <query_field>
                            <name>query</name>
                            <value>histogram_quantile(   0.95,   sum by (le) (     rate(prometheus_http_request_duration_seconds_bucket[5m])   ) )</value>
                        </query_field>
                    </query_fields>
                    <headers>
                        <header>
                            <name>Authorization</name>
                            <value>Bearer {$PROM_TOKEN}</value>
                        </header>
                    </headers>
                    <triggers>
                        <trigger>
                            <uuid>83ba297674ff44fb865fd9fab680eb46</uuid>
                            <expression>avg(/Template OpenShift Virtualization/thanos.api.latency.p95,5m)&gt;2</expression>
                            <recovery_mode>RECOVERY_EXPRESSION</recovery_mode>
                            <recovery_expression>avg(/Template OpenShift Virtualization/thanos.api.latency.p95,5m)&lt;1</recovery_expression>
                            <name>Thanos API latency is high</name>
                            <priority>AVERAGE</priority>
                        </trigger>
                    </triggers>
                </item>
