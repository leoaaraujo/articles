                        <item_prototype>
                            <uuid>36863f1c295748f78a4b108c6b7f3b5c</uuid>
                            <name>Node {#NODE} - CPU Usage</name>
                            <type>HTTP_AGENT</type>
                            <key>node.cpu.util[{#NODE}]</key>
                            <value_type>FLOAT</value_type>
                            <units>%</units>
                            <preprocessing>
                                <step>
                                    <type>JSONPATH</type>
                                    <parameters>
                                        <parameter>$.data.result[0].value[1]</parameter>
                                    </parameters>
                                </step>
                            </preprocessing>
                            <url>{$PROM_URL}/api/v1/query</url>
                            <query_fields>
                                <query_field>
                                    <name>query</name>
                                    <value>100 * (1 - avg(rate(node_cpu_seconds_total{mode=&quot;idle&quot;, instance=&quot;{#NODE}&quot;}[5m])))</value>
                                </query_field>
                            </query_fields>
                            <headers>
                                <header>
                                    <name>Authorization</name>
                                    <value>Bearer {$PROM_TOKEN}</value>
                                </header>
